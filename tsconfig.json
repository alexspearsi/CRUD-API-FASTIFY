{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "dist",
		"module": "nodenext",
		"target": "esnext",
		"types": ["node", "vitest"],
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"strictPropertyInitialization": false,
		"jsx": "react-jsx",
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	},
	"exclude": ["node_modules", "dist", "vitest.config.ts", "html", "coverage", "test"]
}
